{
  "name": "pr-manager",
  "version": "1.0.0",
  "description": "Browser-based BYOK PR management dashboard",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "biome check . && tsc --noEmit && vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/strawgate/pr-manager.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/strawgate/pr-manager/issues"
  },
  "homepage": "https://github.com/strawgate/pr-manager#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.2.5",
    "@tanstack/react-query": "^5.90.21",
    "ai": "^6.0.116",
    "octokit": "^5.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  }
}
